# Server Configuration
PORT=5000

# MongoDB Connection (use MongoDB Atlas or local)
MONGODB_URI=mongodb://localhost:27017/portfolioDB
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/portfolioDB

# Email Configuration (for Nodemailer - optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# App Settings
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
